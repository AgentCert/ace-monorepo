# ─── AgentCert .env (example) ────────────────────────────────────────────────
# Copy to `.env` at the repo root and fill in the placeholders.
# The real `.env` is gitignored — never commit secrets.
#
# Reference IP: replace 172.26.0.1 with your VM's bridge / outbound IP.
# (On a single Linux box, this is the docker bridge gateway IP visible to
# both host processes and pods running in a local kind/minikube cluster.)
# Find it with:  ip -4 addr show docker0 | grep inet

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_HOST=172.26.0.1
MONGODB_PORT=27017
MONGODB_DB_NAME=agentcert
MONGODB_USERNAME=admin
MONGODB_PASSWORD=CHANGE_ME
MONGODB_AUTH_SOURCE=admin
MONGO_CONNECTION_STRING=mongodb://localhost:27017

# Auth Service
AUTH_PROXY_PORT=3000
GQL_PROXY_PORT=8081
TARGET_LOCALHOST=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME
REST_PORT=3000
GRPC_PORT=3030

# Portal
PORTAL_ENDPOINT=http://172.26.0.1:8081
LITMUS_SVC_ENDPOINT=http://172.26.0.1:3000
SELF_AGENT=false
INFRA_SCOPE=cluster
INFRA_NAMESPACE=litmus
LITMUS_PORTAL_NAMESPACE=litmus
PORTAL_SCOPE=namespace
ALLOWED_ORIGINS=^(http://|https://|)((localhost|host\.docker\.internal|host\.minikube\.internal)|100\.104\.[0-9]+\.[0-9]+)(:[0-9]+|)$

# ── Image tags (filled by build-all.sh after pushes) ──────────────────────────
SUBSCRIBER_IMAGE=agentcert/litmusportal-subscriber:3.0.0
EVENT_TRACKER_IMAGE=litmuschaos/litmusportal-event-tracker:3.0.0
CONTAINER_RUNTIME_EXECUTOR=k8sapi
ARGO_WORKFLOW_CONTROLLER_IMAGE=litmuschaos/workflow-controller:v3.3.1
ARGO_WORKFLOW_EXECUTOR_IMAGE=litmuschaos/argoexec:v3.3.1
CHAOS_CENTER_SCOPE=cluster
CHAOS_OPERATOR_IMAGE=litmuschaos/chaos-operator:3.0.0
CHAOS_RUNNER_IMAGE=litmuschaos/chaos-runner:3.0.0
CHAOS_EXPORTER_IMAGE=litmuschaos/chaos-exporter:3.0.0
WORKFLOW_HELPER_IMAGE_VERSION=3.0.0
INSTALL_APPLICATION_IMAGE=agentcert/agentcert-install-app:latest
INSTALL_APPLICATION_IMAGE_PULL_POLICY=Always
INSTALL_AGENT_IMAGE=agentcert/agentcert-install-agent:latest
FLASH_AGENT_IMAGE=agentcert/agentcert-flash-agent:latest
AGENT_SIDECAR_IMAGE=agentcert/agent-sidecar:latest
INSTALL_AGENT_IMAGE_PULL_POLICY=Always

# ── Hub Configuration ─────────────────────────────────────────────────────────
VERSION=3.0.0
HUB_BRANCH_NAME=v2.0.x
DEFAULT_HUB_BRANCH_NAME=master
INFRA_DEPLOYMENTS=["app=chaos-exporter", "name=chaos-operator", "app=event-tracker","app=workflow-controller","app=kubernetes-mcp-server","app=prometheus-mcp-server"]
INFRA_COMPATIBLE_VERSIONS=["3.0.0"]
APP_HUB_SOURCE_MODE=custom
AGENT_HUB_SOURCE_MODE=custom
DEFAULT_APP_HUB_PATH=/tmp/default
DEFAULT_AGENT_HUB_PATH=/tmp/default
DEFAULT_APP_HUB_GIT_URL=https://github.com/agentcert/app-charts
DEFAULT_APP_HUB_BRANCH_NAME=main
DEFAULT_AGENT_HUB_GIT_URL=https://github.com/agentcert/agent-charts
DEFAULT_AGENT_HUB_BRANCH_NAME=main
DEFAULT_HUB_GIT_URL=https://github.com/agentcert/chaos-charts
DEFAULT_HUB_BRANCH_NAME=master

# TLS / Frontend
ENABLE_INTERNAL_TLS=false
SKIP_SSL_VERIFY=true
FRONTEND_PORT=2001
WEB_ENABLE_HTTPS=true

# ── Langfuse ──────────────────────────────────────────────────────────────────
# Generate keys in Langfuse UI → Settings → API Keys.
# LANGFUSE_HOST should resolve from BOTH the host process AND in-cluster pods,
# so prefer the docker bridge IP (e.g. http://172.26.0.1:3001) over localhost.
LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME
LANGFUSE_HOST=http://172.26.0.1:3001
LANGFUSE_ORG_ID=agentcert
LANGFUSE_PROJECT_ID=agentcert

# yes = OTEL fault spans use F1/F2 aliases; no = full fault details (local dev only)
BLIND_TRACES=yes

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Get from Azure Portal → Azure OpenAI → Keys and Endpoint.
AZURE_OPENAI_KEY=REPLACE_ME
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Optional, only needed for RAGAS embedding evaluation
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# ── MongoDB connection used by the Go GraphQL server ──────────────────────────
DB_SERVER=mongodb://admin:CHANGE_ME@172.26.0.1:27017/?replicaSet=rs0&authSource=admin
SERVER_ADDR=http://172.26.0.1:8081/query

# ── LiteLLM ───────────────────────────────────────────────────────────────────
# LITELLM_HOST is the proxy URL accessible from the host (port-forwarded or
# docker-compose). LITELLM_MASTER_KEY is also passed as OPENAI_API_KEY.
LITELLM_HOST=http://172.26.0.1:14000
LITELLM_PROFILE=azure
LITELLM_MASTER_KEY=sk-CHANGE_ME

# ── GraphQL Server ────────────────────────────────────────────────────────────
GQL_REST_PORT=8081
GQL_GRPC_PORT=8082
ENABLE_GQL_INTROSPECTION=true
LITMUS_AUTH_GRPC_ENDPOINT=localhost
LITMUS_AUTH_GRPC_PORT=3030
CHAOS_CENTER_UI_ENDPOINT=http://172.26.0.1:8081

# MCP server images & in-cluster URLs
KUBERNETES_MCP_SERVER_IMAGE=quay.io/containers/kubernetes_mcp_server:latest
PROMETHEUS_MCP_SERVER_IMAGE=agentcert/prometheus-mcp-server:latest
PROMETHEUS_MCP_URL=http://prometheus.monitoring.svc.cluster.local:9090
K8S_MCP_URL=http://kubernetes-mcp-server.sock-shop.svc.cluster.local:8081/mcp
PROM_MCP_URL=http://prometheus-mcp-server.sock-shop.svc.cluster.local:9090/mcp

CHAOS_NAMESPACE=litmus
LITMUS_PROJECT_ID=admin-project

# ── Docker Hub (used by build-all.sh) ─────────────────────────────────────────
DOCKERHUB_USERNAME=YOUR_DOCKERHUB_EMAIL_OR_USERNAME
DOCKERHUB_TOKEN=dckr_pat_REPLACE_ME

# ── Chart paths (consumed by GraphQL server) ──────────────────────────────────
AGENT_CHARTS_ROOT=/srv/projects/ace-monorepo/agent-charts
APP_CHARTS_ROOT=/srv/projects/ace-monorepo/app-charts
