# ═════════════════════════════════════════════════════════════════════════════
#  NEW HERE?  Easiest path:   ./scripts/setup.sh
#  It creates .env and asks you only for the values that matter.
#
#  Prefer to edit by hand? For the default all-local `docker compose up`, you
#  only NEED to fill the Azure OpenAI block (search "Azure OpenAI Configuration"
#  below):
#       AZURE_OPENAI_KEY                  ← your Azure OpenAI API key
#       AZURE_OPENAI_ENDPOINT             ← https://<resource>.openai.azure.com/
#       AZURE_OPENAI_CHAT_DEPLOYMENT_NAME ← your chat deployment (e.g. gpt4o)
#  (the certifier/embedding AZURE_* fields reuse the same resource — set them to
#   the same values). EVERYTHING ELSE BELOW HAS A WORKING DEFAULT — leave as-is.
#
#  MongoDB creds, LiteLLM key, and the Langfuse keys are all defaulted (Langfuse
#  keys are auto-provisioned for the local stack). Touch the rest only for
#  non-default setups — see docs/setup/configuration.md.
# ═════════════════════════════════════════════════════════════════════════════
#
# ─── AgentCert .env (example) ────────────────────────────────────────────────
# Copy to `.env` at the repo root and fill in the placeholders.
# The real `.env` is gitignored — never commit secrets.
#
# TWO address classes — do not confuse them:
#  • Host-reachable services (Mongo, auth, graphql — on the host network or
#    published to it): use 127.0.0.1. Works on EVERY VM, no detection needed.
#  • Pod->host callbacks (in-cluster subscriber/agent calling the control plane):
#    MUST use the kind docker-network gateway IP, assigned PER-BOX (often NOT
#    172.26.0.1 — depends how many docker networks exist). setup.sh detects it.
#    By hand:  docker network inspect kind -f '{{range .IPAM.Config}}{{.Gateway}} {{end}}'

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_DB_NAME=agentcert
MONGODB_USERNAME=admin
MONGODB_PASSWORD=1234
MONGODB_AUTH_SOURCE=admin
MONGO_CONNECTION_STRING=mongodb://localhost:27017

# Auth Service
AUTH_PROXY_PORT=3000
GQL_PROXY_PORT=8081
TARGET_LOCALHOST=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=litmus
# NOTE: do NOT set generic REST_PORT / GRPC_PORT here — they are injected
# per-service by docker-compose (auth=3000/3030, graphql=8081/8082). If set
# here, the graphql binary's godotenv.Overload would clobber its 8081/8082.
JWT_SECRET=litmus-portal@123

# Portal
PORTAL_ENDPOINT=http://172.26.0.1:8081
LITMUS_SVC_ENDPOINT=http://172.26.0.1:3000
SELF_AGENT=false
INFRA_SCOPE=cluster
INFRA_NAMESPACE=litmus
LITMUS_PORTAL_NAMESPACE=litmus
PORTAL_SCOPE=namespace
ALLOWED_ORIGINS=^(http://|https://|)((localhost|host\.docker\.internal|host\.minikube\.internal)|172\.[0-9]+\.[0-9]+\.[0-9]+|10\.[0-9]+\.[0-9]+\.[0-9]+|192\.168\.[0-9]+\.[0-9]+)(:[0-9]+|)$

# ── Image tags (filled by build-all.sh after pushes) ──────────────────────────
SUBSCRIBER_IMAGE=agentcert/litmusportal-subscriber:3.0.0
EVENT_TRACKER_IMAGE=litmuschaos/litmusportal-event-tracker:3.0.0
CONTAINER_RUNTIME_EXECUTOR=k8sapi
ARGO_WORKFLOW_CONTROLLER_IMAGE=litmuschaos/workflow-controller:v3.3.1
ARGO_WORKFLOW_EXECUTOR_IMAGE=litmuschaos/argoexec:v3.3.1
CHAOS_CENTER_SCOPE=cluster
CHAOS_OPERATOR_IMAGE=litmuschaos/chaos-operator:3.0.0
CHAOS_RUNNER_IMAGE=litmuschaos/chaos-runner:3.0.0
CHAOS_EXPORTER_IMAGE=litmuschaos/chaos-exporter:3.0.0
WORKFLOW_HELPER_IMAGE_VERSION=3.0.0
INSTALL_APPLICATION_IMAGE=agentcert/agentcert-install-app:latest
INSTALL_APPLICATION_IMAGE_PULL_POLICY=Always
INSTALL_AGENT_IMAGE=agentcert/agentcert-install-agent:latest
FLASH_AGENT_IMAGE=agentcert/agentcert-flash-agent:latest
AGENT_SIDECAR_IMAGE=agentcert/agent-sidecar:latest
INSTALL_AGENT_IMAGE_PULL_POLICY=Always

# ── Hub Configuration ─────────────────────────────────────────────────────────
VERSION=3.0.0
HUB_BRANCH_NAME=v2.0.x
DEFAULT_HUB_BRANCH_NAME=master
INFRA_DEPLOYMENTS=["app=chaos-exporter", "name=chaos-operator", "app=event-tracker","app=workflow-controller","app=kubernetes-mcp-server","app=prometheus-mcp-server"]
INFRA_COMPATIBLE_VERSIONS=["3.0.0"]
APP_HUB_SOURCE_MODE=custom
AGENT_HUB_SOURCE_MODE=custom
DEFAULT_APP_HUB_PATH=/tmp/default
DEFAULT_AGENT_HUB_PATH=/tmp/default
DEFAULT_APP_HUB_GIT_URL=https://github.com/agentcert/app-charts
DEFAULT_APP_HUB_BRANCH_NAME=main
DEFAULT_AGENT_HUB_GIT_URL=https://github.com/agentcert/agent-charts
DEFAULT_AGENT_HUB_BRANCH_NAME=main
DEFAULT_HUB_GIT_URL=https://github.com/agentcert/chaos-charts
DEFAULT_HUB_BRANCH_NAME=master

# TLS / Frontend
ENABLE_INTERNAL_TLS=false
SKIP_SSL_VERIFY=true
FRONTEND_PORT=2001
WEB_ENABLE_HTTPS=true

# ── Langfuse ──────────────────────────────────────────────────────────────────
# Generate keys in Langfuse UI → Settings → API Keys.
# LANGFUSE_HOST should resolve from BOTH the host process AND in-cluster pods,
# so prefer the docker bridge IP (e.g. http://172.26.0.1:3001) over localhost.
LANGFUSE_PUBLIC_KEY=pk-lf-agentcert-local
LANGFUSE_SECRET_KEY=sk-lf-agentcert-local
LANGFUSE_HOST=http://172.26.0.1:4000
LANGFUSE_ORG_ID=agentcert
LANGFUSE_PROJECT_ID=agentcert
# Langfuse UI login — seeded on FIRST boot of a fresh Langfuse DB (LANGFUSE_MODE=local).
# Password must be >= 8 chars.
LANGFUSE_INIT_USER_EMAIL=admin@agentcert.local
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=agentcert-admin

# yes = OTEL fault spans use F1/F2 aliases; no = full fault details (local dev only)
BLIND_TRACES=yes

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Get from Azure Portal → Azure OpenAI → Keys and Endpoint.
AZURE_OPENAI_KEY=REPLACE_ME
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
# LiteLLM model alias the agents request — MUST match a model_name in
# agentcert-stack/litellm-setup/litellm_config.yaml (gpt-4o, with dash).
# NOT the Azure deployment name — that is AZURE_OPENAI_CHAT_DEPLOYMENT_NAME below.
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Optional, only needed for RAGAS embedding evaluation
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# ── MongoDB connection used by the Go GraphQL server ──────────────────────────
DB_SERVER=mongodb://admin:1234@127.0.0.1:27017/?replicaSet=rs0&authSource=admin
SERVER_ADDR=http://172.26.0.1:8081/query

# ── LiteLLM ───────────────────────────────────────────────────────────────────
# LITELLM_HOST is the proxy URL accessible from the host (port-forwarded or
# docker-compose). LITELLM_MASTER_KEY is also passed as OPENAI_API_KEY.
LITELLM_HOST=http://172.26.0.1:14000
LITELLM_PROFILE=azure
LITELLM_MASTER_KEY=sk-agentcert-2026

# ── GraphQL Server ────────────────────────────────────────────────────────────
GQL_REST_PORT=8081
GQL_GRPC_PORT=8082
ENABLE_GQL_INTROSPECTION=true
LITMUS_AUTH_GRPC_ENDPOINT=localhost
LITMUS_AUTH_GRPC_PORT=3030
# URL the in-cluster subscriber pod calls back to (baked into its SERVER_ADDR).
# Must be reachable from inside the K8s cluster — set to the host's LAN IP, not localhost.
SUBSCRIBER_CALLBACK_URL=http://YOUR_HOST_LAN_IP:8081

# MCP server images & in-cluster URLs
KUBERNETES_MCP_SERVER_IMAGE=quay.io/containers/kubernetes_mcp_server:latest
PROMETHEUS_MCP_SERVER_IMAGE=agentcert/prometheus-mcp-server:latest
K8S_MCP_URL=http://kubernetes-mcp-server.sock-shop.svc.cluster.local:8081/mcp
PROM_MCP_URL=http://prometheus-mcp-server.sock-shop.svc.cluster.local:8083/mcp

CHAOS_NAMESPACE=litmus
LITMUS_PROJECT_ID=admin-project

# ── Docker Hub (used by build-all.sh) ─────────────────────────────────────────
DOCKERHUB_USERNAME=YOUR_DOCKERHUB_EMAIL_OR_USERNAME
DOCKERHUB_TOKEN=dckr_pat_REPLACE_ME

# ── Chart paths (consumed by GraphQL server) ──────────────────────────────────
AGENT_CHARTS_ROOT=/srv/projects/ace-monorepo/agent-charts
APP_CHARTS_ROOT=/srv/projects/ace-monorepo/app-charts

# Image override for the LiteLLM proxy compose stack
LITELLM_PROXY_IMAGE=docker.io/litellm/litellm:v1.82.0-stable

# Additional MCP URL used by the prometheus-mcp deployment
PROMETHEUS_MCP_URL=http://prometheus.monitoring.svc.cluster.local:9090


# =============================================================================
# Certifier (AgentCert) — sole source of truth for certifier env vars
# Docker Compose at certifier/docker-compose.yml loads this file via env_file: ../.env
# Configs that reference these vars: certifier/configs/configs.json (models.gpt-4o,
# models.gpt-5.2, models.embedding_model, mongodb, storage_connections).
# =============================================================================

# -- MongoDB
# Host runs (CLI / scripts): point at the existing Litmus mongo with auth + replSet.
# Docker compose: the compose env block overrides MONGODB_CONNECTION_STRING to
# host.docker.internal with `directConnection=true` so in-container pymongo
# bypasses the replica-set topology lookup (which advertises localhost:27017).
MONGODB_CONNECTION_STRING=mongodb://admin:1234@127.0.0.1:27017/agentcert?replicaSet=rs0&authSource=admin
MONGODB_DATABASE=agentcert

# -- Image tag used by certifier/docker-compose.yml. Leave unset to build locally
# (tag becomes `certifier:latest`). Set to a registry path to pull instead
# (e.g. agentcert/certifier:latest, or a private registry / SHA digest).
# `./scripts/start-local-services.sh --pull-certifier` uses this value too.
CERTIFIER_IMAGE=agentcert/certifier:latest

# -- API server
API_HOST=0.0.0.0
API_PORT=8000
API_MAX_CONCURRENT_TASKS=4
API_MAX_CONCURRENT_CERT_TASKS=2

# -- MongoDB collection names (created on first use)
API_TASK_COLLECTION=pipeline_tasks
CERT_TASK_COLLECTION=certification_tasks
CERT_METADATA_COLLECTION=certification_metadata
AGG_CATEGORY_COLLECTION=aggregated_category_metadata

# -- Workspace directories (relative inside the container; compose mounts to /app/workspace)
WORKSPACE_DIR=workspace
CERT_WORKSPACE_DIR=workspace/cert

# -- Azure OpenAI extraction model (configs.json -> models.gpt-4o, model_type=standard)
# Note: AZURE_OPENAI_API_KEY mirrors AZURE_OPENAI_KEY above for clarity; the
# certifier reads AZURE_OPENAI_API_KEY (the standard SDK name).
AZURE_OPENAI_API_KEY=REPLACE_ME
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt4o

# -- Azure OpenAI reasoning model (configs.json -> models.gpt-5.2, model_type=reasoning)
# AzureLLMClient strips `temperature` for reasoning models. If you don't have
# a dedicated o-series deployment, reuse the gpt-4o credentials below.
AZURE_OPENAI_GPT5_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_GPT5_API_KEY=REPLACE_ME
AZURE_OPENAI_GPT5_API_VERSION=2024-12-01-preview
AZURE_OPENAI_GPT5_CHAT_DEPLOYMENT_NAME=gpt4o

# -- Azure OpenAI embedding model (configs.json -> models.embedding_model)
# Reuses the gpt-4o resource by default. If no embedding deployment exists,
# AZURE_EMBEDDING_MODEL can be stubbed with the chat deployment to satisfy
# AzureLLMClient init; embeddings are not invoked along chat-only paths.
AZURE_EMBEDDING_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_EMBEDDING_API_KEY=REPLACE_ME
AZURE_EMBEDDING_API_VERSION=2024-02-01
AZURE_EMBEDDING_MODEL=gpt4o

# -- Azure Content Safety (optional; RAI compliance checks in metrics_extractor)
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_API_KEY=

# -- Azure Blob Storage (optional; required when storage_config.type = blob_storage / hybrid)
AZURE_STORAGE_CONNECTION_STRING=

# -- Python path inside the certifier container (set by Dockerfile too)
PYTHONPATH=/app

# =============================================================================
# Docker Compose one-command bring-up (root docker-compose.yml)
# `docker compose up` reads these. They select cluster + langfuse + litellm
# behaviour without editing any compose file.
# =============================================================================

# -- Kubernetes cluster strategy used by the one-shot `cluster-init` service:
#      auto   (default) probe the mounted ~/.kube/config; reuse if it works,
#                       otherwise create a local kind cluster.
#      cloud            reuse an existing cloud context (AKS/EKS/GKE). Mounts
#                       ~/.azure ~/.aws ~/.config/gcloud for exec-auth. Set
#                       HOST_PUBLIC_IP so in-cluster pods can call back.
#      local            reuse an existing local context (kind/minikube/k3s).
#      fresh | kind     always create/ensure a local kind cluster.
CLUSTER_MODE=auto
KIND_CLUSTER_NAME=agentcert
# Host kube directory (not the file) mounted into cluster-init/graphql.
# Leave unset to default to ~/.kube; if set, use an ABSOLUTE path.
# HOST_KUBE_DIR=/home/youruser/.kube
# Only for CLUSTER_MODE=cloud: VM address in-cluster pods call back to.
HOST_PUBLIC_IP=

# -- Langfuse: local (vendored stack) | external (use LANGFUSE_HOST/keys above)
LANGFUSE_MODE=local
# -- Langfuse host for compose-bridge services (litellm, certifier): they reach
#    Langfuse by service name, not the kind-gateway IP. Default = local; for
#    LANGFUSE_MODE=external set this to the same URL as LANGFUSE_HOST.
LANGFUSE_HOST_COMPOSE=http://langfuse-web:3000
# -- LiteLLM: local (proxy in compose) | external (use LITELLM_HOST)
LITELLM_MODE=local
# -- MongoDB: local (mongo:5 rs0 in compose) | external (reuse via DB_SERVER)
MONGO_MODE=local

# -- Profiles activated by the *_MODE switches (Compose reads this automatically).
#    One token per *_MODE=local: mongo, langfuse, litellm.
COMPOSE_PROFILES=mongo,langfuse,litellm

# -- Host ports published by supporting services (override on clash)
WEB_PORT=2001
LANGFUSE_PORT=4000
LITELLM_PORT=14000
MINIO_API_PORT=9090       # Langfuse MinIO S3 API (move if 9090 is taken)
MINIO_CONSOLE_PORT=9091   # Langfuse MinIO console (127.0.0.1 only)
