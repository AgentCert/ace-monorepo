# ─── AgentCert monorepo build paths ───────────────────────────────────────────
# Sourced by scripts/azure_build/start-agentcert-v2.sh via:
#   --paths-file <repo-root>/build-paths.env
#
# All *_ROOT paths resolve relative to this file's own location, so the file
# works from any checkout location and is safe to commit. Submodule paths are
# guaranteed by .gitmodules at the monorepo root.
#
# Quickstart:
#   cp build-paths.env.example build-paths.env   # or symlink, or use the example directly
#   bash scripts/azure_build/start-agentcert-v2.sh \
#       --env-file   $(pwd)/.env \
#       --paths-file $(pwd)/build-paths.env

# Monorepo root — derived from this file's location so paths stay portable.
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Submodule checkout paths ──────────────────────────────────────────────────
AGENTCERT_ROOT="${REPO_ROOT}/AgentCert"
APP_CHARTS_ROOT="${REPO_ROOT}/app-charts"
AGENT_CHARTS_ROOT="${REPO_ROOT}/agent-charts"
FLASH_AGENT_ROOT="${REPO_ROOT}/flash-agent"
AGENT_SIDECAR_ROOT="${REPO_ROOT}/agent-sidecar"
CHAOS_CHARTS_ROOT="${REPO_ROOT}/chaos-charts"
CERTIFIER_ROOT="${REPO_ROOT}/certifier"
AGENTCERT_STACK_ROOT="${REPO_ROOT}/agentcert-stack"

# ── Upstream URLs (used as defaults by start-agentcert-v2.sh) ─────────────────
AGENTCERT_GIT_URL=https://github.com/AgentCert/AgentCert.git
APP_CHARTS_GIT_URL=https://github.com/AgentCert/app-charts.git
AGENT_CHARTS_GIT_URL=https://github.com/AgentCert/agent-charts.git
FLASH_AGENT_GIT_URL=https://github.com/AgentCert/flash-agent.git
AGENT_SIDECAR_GIT_URL=https://github.com/AgentCert/agent-sidecar.git
CHAOS_CHARTS_GIT_URL=https://github.com/AgentCert/chaos-charts.git
CERTIFIER_GIT_URL=https://github.com/AgentCert/certifier.git
AGENTCERT_STACK_GIT_URL=https://github.com/AgentCert/agentcert-stack.git

# Default branch. chaos-charts upstream tracks 'master' instead of 'main' —
# override per-repo via *_GIT_BRANCH if needed.
GIT_BRANCH=main
CHAOS_CHARTS_GIT_BRANCH=master
